{
  "name": "@simple-monorepo/ui",
  "version": "0.1.0",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "@radix-ui/react-form": ">=0.1.8 <1",
    "next": ">=16 <17",
    "react": ">=19 <20",
    "react-dom": ">=19 <20"
  },
  "devDependencies": {
    "@radix-ui/react-form": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "next": "*",
    "typescript": "*",
    "react": "*",
    "react-dom": "*",
    "tsup": "^8.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist --rootDir src"
  }
}
